# Caminho do arquivo SQLite (relativo ao cwd em `backend/` ou absoluto)
DATABASE_PATH=./data/app.sqlite

# Porta HTTP
PORT=3000

# Origem do frontend (CORS)
FRONTEND_ORIGIN=http://localhost:8080

# Autenticação demo (sessão local; alterar em produção)
AUTH_LOGIN_USERNAME=sevenadmin
AUTH_LOGIN_PASSWORD=@Seven2026

# Segredo JWT (assinatura de tokens)
JWT_SECRET=change-me-in-production-use-long-random-string

# Nome do cookie HttpOnly da sessão (opcional)
# AUTH_COOKIE_NAME=rt_session

# Pasta docs do monorepo (PDF LC 214, planilhas) — relativo ao cwd em backend/
DOCS_PATH=../docs

# URLs externas: copiar env.sites.example para env.sites e definir URL_SITE
