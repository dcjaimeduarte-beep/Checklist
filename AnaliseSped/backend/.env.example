# Caminho do arquivo SQLite (relativo ao cwd em `backend/` ou absoluto)
DATABASE_PATH=./data/app.sqlite

# Porta HTTP
PORT=3000

# Origem do frontend (CORS)
FRONTEND_ORIGIN=http://localhost:8080

# Autenticação (alterar em produção)
AUTH_LOGIN_USERNAME=admin
AUTH_LOGIN_PASSWORD=@AnaliseSped2026

# Segredo JWT (assinatura de tokens — usar string longa e aleatória em produção)
JWT_SECRET=change-me-in-production-use-long-random-string

# Nome do cookie HttpOnly da sessão (opcional)
# AUTH_COOKIE_NAME=analisesped_session

# ── E-mail (opcional — para envio de relatórios) ──────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu@email.com.br
# SMTP_PASS=sua-senha-ou-app-password
# SMTP_FROM=AnaliseSped <seu@email.com.br>
